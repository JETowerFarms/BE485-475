# Backend Environment Configuration
# Copy this to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# Database Configuration
# For local development:
DB_HOST=localhost
# For Docker:
# DB_HOST=db
DB_PORT=5432
DB_NAME=michigan_solar
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000

# CORS Configuration
# WARNING: '*' allows all origins - restrict to specific domains in production
# For local dev (be explicit):
CORS_ORIGIN=http://localhost:3000,exp://192.168.1.100:8081
# For production, use your actual domain:
# CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Caching
CACHE_TTL=3600
ENABLE_CACHE=true

# Data Grid Configuration
GRID_SPACING=0.000667
GRID_MIN_LAT=41.5
GRID_MAX_LAT=48.5
GRID_MIN_LNG=-90.5
GRID_MAX_LNG=-82.0

# Query Limits
MAX_BBOX_POINTS=10000
MAX_FARM_POINTS=50000

# Pricing snapshots are generated from the checked-in files under backend/data/prices.
