# Docker environment variables
# Used by docker-compose.yml

# Database password (used by both db and api services)
DB_PASSWORD=solarpassword123

# CORS origin (comma-separated list for production)
# For development, allow Metro bundler (port 8081) and localhost
CORS_ORIGIN=http://localhost:8081,http://127.0.0.1:8081,http://10.0.2.2:8080

# Backend server port
PORT=3001

# Node environment
NODE_ENV=development

# Body parser limits
BODY_LIMIT=10mb

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Trust proxy (for reverse proxies)
TRUST_PROXY=1

# NREL PVWatts API key (https://developer.nrel.gov)
NREL_API_KEY=SP99xSHv1O1gGQjQFtXfJ2QuUzRILBOnPDo2HZTe

# pgAdmin credentials (only used when running with --profile dev)
PGADMIN_EMAIL=admin@solar.com
PGADMIN_PASSWORD=admin
